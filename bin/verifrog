#!/usr/bin/env bash
#
# verifrog — wrapper script for the Verifrog Verilog testing framework.
#
# Replaces verbose "dotnet run --project ..." incantations with simple commands:
#   verifrog init [dir]
#   verifrog build [dir]
#   verifrog clean [dir]
#   verifrog test [dir] [-- dotnet-test-args...]
#   verifrog debug [dir] [--script <path>]
#   verifrog vcd <file.vcd> [options]
#
# VERIFROG_ROOT is auto-detected from this script's location.
# Override by setting VERIFROG_ROOT in your environment.

set -euo pipefail

# ---- Auto-detect VERIFROG_ROOT ----

# Resolve symlinks to find the real script location
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

if [[ -z "${VERIFROG_ROOT:-}" ]]; then
    export VERIFROG_ROOT="$(dirname "$SCRIPT_DIR")"
fi

CLI_PROJECT="$VERIFROG_ROOT/src/Verifrog.Cli/Verifrog.Cli.fsproj"
VCD_PROJECT="$VERIFROG_ROOT/src/Verifrog.Vcd.Cli/Verifrog.Vcd.Cli.fsproj"

# ---- Helpers ----

die() { echo "Error: $*" >&2; exit 1; }

# Find verifrog.toml by walking up from a directory
find_toml() {
    local dir="$1"
    dir="$(cd "$dir" && pwd)"
    while [[ "$dir" != "/" ]]; do
        [[ -f "$dir/verifrog.toml" ]] && echo "$dir/verifrog.toml" && return 0
        dir="$(dirname "$dir")"
    done
    return 1
}

# Read the [test].output value from verifrog.toml (default: "build")
read_build_dir() {
    local toml="$1"
    # Simple grep — works for output = "build" style lines
    local val
    val=$(grep -E '^\s*output\s*=' "$toml" | head -1 | sed 's/.*= *"\([^"]*\)".*/\1/')
    echo "${val:-build}"
}

# Detect OS and set library path variable name
lib_path_var() {
    case "$(uname -s)" in
        Darwin) echo "DYLD_LIBRARY_PATH" ;;
        *)      echo "LD_LIBRARY_PATH" ;;
    esac
}

usage() {
    cat <<'USAGE'
verifrog — Verilog testing framework

Commands:
  init [dir]                    Scaffold a new verifrog project
  build [dir]                   Build Verilator model from verifrog.toml
  clean [dir]                   Remove build artifacts
  test [dir] [--report [path]]  Build (if needed) and run tests
  debug [dir] [--script <f>]    Interactive simulation debugger
  vcd <file.vcd> [options]      Analyze VCD waveform files
  results <junit.xml> [-o path] Convert JUnit XML to Markdown report

DAP Debug Session (persistent, for AI/SSH/CI):
  debug-dap [dir] [--test "name"]   Launch debug session
  debug-eval <expr>                 Evaluate F# expression
  debug-step [n]                    Step N sim cycles (default: 1)
  debug-read <signal>               Read signal value
  debug-signals [filter]            List signals (optional filter)
  debug-checkpoint <name>           Save sim state
  debug-restore <name>              Restore sim state
  debug-quit                        End debug session

Options:
  -h, --help                    Show this help

Examples:
  verifrog init my_project
  verifrog build
  verifrog test
  verifrog test samples/counter
  verifrog test --category Smoke             # Run only smoke tests
  verifrog test --report                    # Run tests + generate test-results.md
  verifrog test --report results.md         # Custom report path
  verifrog test -- --filter "counter"       # Pass args to test runner
  verifrog results test-results.xml         # Convert existing XML to markdown
  verifrog debug
  verifrog debug --script probe.txt
  verifrog vcd output/sim.vcd --signal "fsm*" --debug

  # DAP debug session (for Claude / SSH)
  verifrog debug-dap samples/counter
  verifrog debug-read count
  verifrog debug-step 10
  verifrog debug-read count
  verifrog debug-checkpoint before_overflow
  verifrog debug-eval "sim.ReadOrFail(\"overflow\")"
  verifrog debug-quit
USAGE
}

# ---- Commands ----

cmd_init() {
    local dir="${1:-.}"
    dotnet run --project "$CLI_PROJECT" -- init "$dir"
}

cmd_build() {
    local dir="${1:-.}"
    dotnet run --project "$CLI_PROJECT" -- build "$dir"
}

cmd_clean() {
    local dir="${1:-.}"
    dotnet run --project "$CLI_PROJECT" -- clean "$dir"
}

cmd_test() {
    local dir="."
    local report=false
    local report_path=""
    local category=""
    local dotnet_args=()

    # Parse args: our flags before "--", everything after "--" goes to dotnet
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --report)
                report=true
                if [[ "${2:-}" != "" && "${2:-}" != -* && "${2:-}" != "--" ]]; then
                    report_path="$2"
                    shift
                fi
                shift
                ;;
            --category)
                [[ -z "${2:-}" ]] && die "--category requires a value (Smoke, Unit, Parametric, Integration, Stress, Golden, Regression)"
                category="$2"
                shift 2
                ;;
            --)
                shift
                dotnet_args=("$@")
                break
                ;;
            *)
                dir="$1"
                shift
                ;;
        esac
    done

    # Find verifrog.toml
    local toml
    toml=$(find_toml "$dir") || die "verifrog.toml not found (searched up from $dir). Run 'verifrog init' first."

    local project_root
    project_root="$(dirname "$toml")"

    local build_dir
    build_dir="$project_root/$(read_build_dir "$toml")"

    local lib_ext
    case "$(uname -s)" in
        Darwin) lib_ext="dylib" ;;
        *)      lib_ext="so" ;;
    esac

    local lib_path="$build_dir/libverifrog_sim.$lib_ext"

    # Auto-build if library doesn't exist
    if [[ ! -f "$lib_path" ]]; then
        echo "Library not found at $lib_path — building..."
        cmd_build "$dir"
    fi

    # Find test project
    local test_proj=""
    if [[ -d "$project_root/tests" ]]; then
        # Look for .fsproj in tests/
        test_proj=$(find "$project_root/tests" -maxdepth 2 -name "*.fsproj" | head -1)
    fi

    if [[ -z "$test_proj" ]]; then
        # Fall back to framework's own tests
        test_proj="$VERIFROG_ROOT/tests/Verifrog.Tests/Verifrog.Tests.fsproj"
    fi

    if [[ ! -f "$test_proj" ]]; then
        die "No test project found. Expected .fsproj in $project_root/tests/"
    fi

    local test_dir
    test_dir="$(dirname "$test_proj")"

    # Set library path
    local path_var
    path_var=$(lib_path_var)
    export "$path_var"="$build_dir${!path_var:+:${!path_var}}"

    # Set up report generation and category filter
    local junit_xml=""
    local extra_args=()
    if [[ -n "$category" ]]; then
        extra_args+=("--filter-test-list" "$category")
    fi
    if [[ "$report" == true ]]; then
        junit_xml="$project_root/test-results.xml"
        if [[ -z "$report_path" ]]; then
            report_path="$project_root/test-results.md"
        fi
        extra_args+=("--junit-summary" "$junit_xml")
    fi

    echo "Running tests: $(basename "$test_proj")"
    echo "  Library: $lib_path"
    if [[ -n "$category" ]]; then
        echo "  Category: $category"
    fi
    if [[ "$report" == true ]]; then
        echo "  Report: $report_path"
    fi
    echo ""

    # Run tests. Use --sequenced to avoid parallel sim creation which can crash
    # the test host (Verilator's global state is not thread-safe across instances).
    local exit_code=0
    dotnet run --project "$test_proj" -- --sequenced "${extra_args[@]+"${extra_args[@]}"}" "${dotnet_args[@]+"${dotnet_args[@]}"}" || exit_code=$?

    # Generate markdown report
    if [[ "$report" == true && -f "$junit_xml" ]]; then
        echo ""
        dotnet fsi "$SCRIPT_DIR/junit-to-md.fsx" "$junit_xml" "$report_path" 2>&1
    fi

    return $exit_code
}

cmd_results() {
    local input=""
    local output=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -o|--output)
                output="$2"
                shift 2
                ;;
            *)
                input="$1"
                shift
                ;;
        esac
    done

    if [[ -z "$input" ]]; then
        echo "Usage: verifrog results <junit.xml> [-o output.md]"
        echo ""
        echo "Convert JUnit XML test results to Markdown."
        echo ""
        echo "Examples:"
        echo "  verifrog results test-results.xml                 # Print to stdout"
        echo "  verifrog results test-results.xml -o results.md   # Write to file"
        exit 0
    fi

    [[ -f "$input" ]] || die "File not found: $input"

    if [[ -n "$output" ]]; then
        dotnet fsi "$SCRIPT_DIR/junit-to-md.fsx" "$input" "$output"
    else
        dotnet fsi "$SCRIPT_DIR/junit-to-md.fsx" "$input"
    fi
}

cmd_debug() {
    dotnet run --project "$CLI_PROJECT" -- debug "$@"
}

cmd_debug_server() {
    local dir="${1:-.}"
    local toml
    toml=$(find_toml "$dir") || die "verifrog.toml not found"
    local project_root
    project_root="$(dirname "$toml")"
    local build_dir
    build_dir="$project_root/$(read_build_dir "$toml")"

    local path_var
    path_var=$(lib_path_var)
    export "$path_var"="$build_dir${!path_var:+:${!path_var}}"

    dotnet run --project "$CLI_PROJECT" -- debug-server "$dir"
}

cmd_vcd() {
    [[ $# -eq 0 ]] && die "Usage: verifrog vcd <file.vcd> [options]"
    dotnet run --project "$VCD_PROJECT" -- "$@"
}

# ---- Debug-DAP session management ----
#
# These commands manage a persistent netcoredbg debug session. The session
# runs netcoredbg in the background with its stdin/stdout connected via FIFOs.
# This allows multiple bash invocations to send commands to the same paused
# debugger — exactly what's needed for AI-assisted debugging (Claude) and SSH.
#
# Session state lives in /tmp/verifrog-debug-<pid>/
#   - pid         — netcoredbg process ID
#   - in.fifo     — write commands here
#   - out.fifo    — read responses here
#   - project_dir — project directory for context

SESSION_DIR_PREFIX="/tmp/verifrog-debug"

# Find the active session directory (most recent)
find_session() {
    local latest=""
    for d in "$SESSION_DIR_PREFIX"-*/; do
        [[ -d "$d" ]] || continue
        local pidfile="$d/pid"
        [[ -f "$pidfile" ]] || continue
        local pid
        pid=$(cat "$pidfile")
        if kill -0 "$pid" 2>/dev/null; then
            latest="$d"
        else
            # Stale session — clean up
            rm -rf "$d"
        fi
    done
    if [[ -n "$latest" ]]; then
        echo "$latest"
        return 0
    fi
    return 1
}

# Find netcoredbg binary
find_netcoredbg() {
    # Check VERIFROG_NETCOREDBG override first
    if [[ -n "${VERIFROG_NETCOREDBG:-}" ]] && [[ -x "$VERIFROG_NETCOREDBG" ]]; then
        echo "$VERIFROG_NETCOREDBG"
        return 0
    fi
    # Check common locations
    local candidates=(
        "$HOME/.local/bin/netcoredbg/netcoredbg"
        "/usr/local/bin/netcoredbg"
        "/usr/bin/netcoredbg"
    )
    for c in "${candidates[@]}"; do
        [[ -x "$c" ]] && { echo "$c"; return 0; }
    done
    # Fall back to PATH
    command -v netcoredbg 2>/dev/null && return 0
    return 1
}

# Send a command to the debug session broker and read the response.
# The broker (verifrog-dap-session) handles netcoredbg I/O and uses
# "---END---" as a response delimiter.
session_send() {
    local session_dir="$1"
    shift
    local cmd="$*"

    local cmd_fifo="$session_dir/cmd.fifo"
    local resp_fifo="$session_dir/resp.fifo"

    # Send command to broker
    echo "$cmd" > "$cmd_fifo"

    # Read response until delimiter (open FIFO once via fd to avoid per-line reopen)
    local output=""
    local line
    exec 5< "$resp_fifo"
    while IFS= read -r line <&5; do
        [[ "$line" == "---END---" ]] && break
        output+="$line"$'\n'
    done
    exec 5<&-

    # Print non-empty output
    [[ -n "$output" ]] && echo "$output" | sed '/^$/d'
}

cmd_debug_dap() {
    local dir="."
    local test_filter=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --test)
                test_filter="$2"
                shift 2
                ;;
            *)
                dir="$1"
                shift
                ;;
        esac
    done

    # Check for existing session
    if find_session >/dev/null 2>&1; then
        die "Debug session already running. Use 'verifrog debug-quit' first."
    fi

    # Find netcoredbg
    local ncdbg
    ncdbg=$(find_netcoredbg) || die "netcoredbg not found. Install it or set VERIFROG_NETCOREDBG."

    # Find verifrog.toml and build info
    local toml
    toml=$(find_toml "$dir") || die "verifrog.toml not found (searched up from $dir)"
    local project_root
    project_root="$(dirname "$toml")"
    local build_dir
    build_dir="$project_root/$(read_build_dir "$toml")"

    # Find test project — check project-local tests/ first, then repo-level tests/
    local test_proj=""
    if [[ -d "$project_root/tests" ]]; then
        test_proj=$(find "$project_root/tests" -maxdepth 2 -name "*.fsproj" | head -1)
    fi
    if [[ -z "$test_proj" && -d "$VERIFROG_ROOT/tests" ]]; then
        test_proj=$(find "$VERIFROG_ROOT/tests" -maxdepth 2 -name "*.fsproj" | head -1)
    fi
    [[ -n "$test_proj" ]] || die "No test project (.fsproj) found in $project_root/tests/ or $VERIFROG_ROOT/tests/"

    # Find the built DLL
    local test_name
    test_name=$(basename "$test_proj" .fsproj)
    local test_dll="$(dirname "$test_proj")/bin/Debug/net8.0/$test_name.dll"

    # Build in Debug config if DLL doesn't exist
    if [[ ! -f "$test_dll" ]]; then
        echo "Building test project..."
        dotnet build "$test_proj" -c Debug --nologo -q 2>&1 || die "Build failed"
    fi
    [[ -f "$test_dll" ]] || die "Test DLL not found: $test_dll. Run 'dotnet build $test_proj -c Debug' first."

    # Symlink native library next to the test DLL.
    # macOS SIP strips DYLD_LIBRARY_PATH from child processes launched by signed
    # binaries (netcoredbg → dotnet), so we place the lib where DllImport can find it.
    local lib_ext
    case "$(uname -s)" in
        Darwin) lib_ext="dylib" ;;
        *)      lib_ext="so" ;;
    esac
    local native_lib="$build_dir/libverifrog_sim.$lib_ext"
    local dll_dir
    dll_dir="$(dirname "$test_dll")"
    if [[ -f "$native_lib" && ! -e "$dll_dir/libverifrog_sim.$lib_ext" ]]; then
        ln -sf "$native_lib" "$dll_dir/libverifrog_sim.$lib_ext"
    fi

    # Create session directory with FIFOs for the broker
    local session_dir
    session_dir=$(mktemp -d "${SESSION_DIR_PREFIX}-XXXXXX")
    mkfifo "$session_dir/cmd.fifo"
    mkfifo "$session_dir/resp.fifo"
    echo "$project_root" > "$session_dir/project_dir"

    # Set library path
    local path_var
    path_var=$(lib_path_var)
    export "$path_var"="$build_dir${!path_var:+:${!path_var}}"

    # netcoredbg launch args — the broker handles the two-stage breakpoint setup
    local ncdbg_args=(
        --interpreter=cli
        -- dotnet exec "$test_dll" --sequenced
    )
    if [[ -n "$test_filter" ]]; then
        ncdbg_args+=(--filter-test-case "$test_filter")
    fi

    # Launch the session broker in the background
    local broker="$SCRIPT_DIR/verifrog-dap-session"
    [[ -x "$broker" ]] || die "Session broker not found: $broker"

    "$broker" "$session_dir" "$ncdbg" "${ncdbg_args[@]}" &
    local broker_pid=$!
    echo "$broker_pid" > "$session_dir/pid"

    # Wait for Stage 1 (main breakpoint hit)
    local retries=0
    while [[ $retries -lt 20 ]]; do
        if [[ -f "$session_dir/status" ]]; then
            local status
            status=$(cat "$session_dir/status")
            if [[ "$status" == "STAGE1_DONE" ]]; then
                break
            elif [[ "$status" == INIT_ERROR* ]]; then
                rm -rf "$session_dir"
                die "Debug session init failed: $status"
            fi
        fi
        if ! kill -0 "$broker_pid" 2>/dev/null; then
            rm -rf "$session_dir"
            die "Debug session failed to start (broker exited). Check that netcoredbg is arm64-native."
        fi
        sleep 1
        retries=$((retries + 1))
    done

    if [[ $retries -ge 20 ]]; then
        kill "$broker_pid" 2>/dev/null
        rm -rf "$session_dir"
        die "Debug session timed out waiting for main breakpoint"
    fi

    echo "Debug session started (paused at main)"
    echo "  Session:  $session_dir"
    echo "  PID:      $broker_pid"
    echo "  Project:  $project_root"
    echo "  Test DLL: $test_dll"
    if [[ -n "$test_filter" ]]; then
        echo "  Filter:   $test_filter"
    fi
    echo ""
    echo "Commands:"
    echo "  verifrog debug-eval <expr>         Evaluate F# expression"
    echo "  verifrog debug-step [n]            Step N sim cycles"
    echo "  verifrog debug-read <signal>       Read signal value"
    echo "  verifrog debug-signals [filter]    List signals"
    echo "  verifrog debug-checkpoint <name>   Save sim state"
    echo "  verifrog debug-restore <name>      Restore sim state"
    echo "  verifrog debug-quit                End session"
    echo ""
    echo "To enter a test, set a breakpoint and continue:"
    echo "  verifrog debug-eval 'break SimTests.fs:22'"
    echo "  verifrog debug-eval 'continue'"
}

cmd_debug_eval() {
    local session_dir
    session_dir=$(find_session) || die "No active debug session. Run 'verifrog debug-dap' first."
    [[ $# -gt 0 ]] || die "Usage: verifrog debug-eval <expression>"
    local expr="$*"
    # If it looks like a debugger command (break, continue, etc.), send raw
    case "$expr" in
        break*|continue|c|run|r|next|n|step|s|finish|info*|backtrace|bt|list*|delete*|disable*|enable*)
            session_send "$session_dir" "$expr"
            ;;
        *)
            session_send "$session_dir" "print $expr"
            ;;
    esac
}

cmd_debug_step() {
    local session_dir
    session_dir=$(find_session) || die "No active debug session. Run 'verifrog debug-dap' first."
    local n="${1:-1}"
    # StepCycles has a non-optional int param (debugger-compatible), returns cycle count
    session_send "$session_dir" "print sim.StepCycles($n)"
}

cmd_debug_read() {
    local session_dir
    session_dir=$(find_session) || die "No active debug session. Run 'verifrog debug-dap' first."
    [[ $# -gt 0 ]] || die "Usage: verifrog debug-read <signal>"
    local signal="$1"
    session_send "$session_dir" "print sim.ReadOrFail(\"$signal\")"
}

cmd_debug_signals() {
    local session_dir
    session_dir=$(find_session) || die "No active debug session. Run 'verifrog debug-dap' first."
    # ListSignals returns F# list — netcoredbg will show it as a nested structure
    # Filtering with F# lambdas doesn't work in netcoredbg's C# evaluator
    session_send "$session_dir" "print sim.ListSignals()"
}

cmd_debug_checkpoint() {
    local session_dir
    session_dir=$(find_session) || die "No active debug session. Run 'verifrog debug-dap' first."
    [[ $# -gt 0 ]] || die "Usage: verifrog debug-checkpoint <name>"
    # Save uses non-optional overload for debugger compatibility
    session_send "$session_dir" "print sim.Save(\"$1\")"
}

cmd_debug_restore() {
    local session_dir
    session_dir=$(find_session) || die "No active debug session. Run 'verifrog debug-dap' first."
    [[ $# -gt 0 ]] || die "Usage: verifrog debug-restore <name>"
    # Restore uses non-optional overload that returns cycle count
    session_send "$session_dir" "print sim.Restore(\"$1\")"
}

cmd_debug_quit() {
    local session_dir
    session_dir=$(find_session) || die "No active debug session."

    local pid
    pid=$(cat "$session_dir/pid")

    # Tell the broker to shut down (it sends 'quit' to netcoredbg and cleans up)
    echo "__quit__" > "$session_dir/cmd.fifo" 2>/dev/null || true

    # Read the final response (open FIFO once)
    local line
    exec 5< "$session_dir/resp.fifo" 2>/dev/null || true
    while IFS= read -r line <&5 2>/dev/null; do
        [[ "$line" == "---END---" ]] && break
        echo "$line"
    done
    exec 5<&- 2>/dev/null || true

    # Wait for broker to exit, force kill if needed
    sleep 1
    kill "$pid" 2>/dev/null || true
    wait "$pid" 2>/dev/null || true

    # Clean up any leftover session dir (broker normally does this)
    rm -rf "$session_dir" 2>/dev/null || true
    echo "Debug session ended."
}

# ---- Dispatch ----

[[ $# -eq 0 ]] && { usage; exit 0; }

case "$1" in
    init)              shift; cmd_init "$@" ;;
    build)             shift; cmd_build "$@" ;;
    clean)             shift; cmd_clean "$@" ;;
    test)              shift; cmd_test "$@" ;;
    debug)             shift; cmd_debug "$@" ;;
    debug-server)      shift; cmd_debug_server "$@" ;;
    debug-dap)         shift; cmd_debug_dap "$@" ;;
    debug-eval)        shift; cmd_debug_eval "$@" ;;
    debug-step)        shift; cmd_debug_step "$@" ;;
    debug-read)        shift; cmd_debug_read "$@" ;;
    debug-signals)     shift; cmd_debug_signals "$@" ;;
    debug-checkpoint)  shift; cmd_debug_checkpoint "$@" ;;
    debug-restore)     shift; cmd_debug_restore "$@" ;;
    debug-quit)        shift; cmd_debug_quit ;;
    vcd)               shift; cmd_vcd "$@" ;;
    results)           shift; cmd_results "$@" ;;
    -h|--help|help) usage ;;
    *)       die "Unknown command: $1. Run 'verifrog --help' for usage." ;;
esac
