# Makefile for libverifrog_sim — builds Verilator model + generic C shim
#
# Usage:
#   make sim-lib TOP=counter RTL_SOURCES="path/to/counter.v" [BUILD_DIR=build]
#
# The Makefile:
#   1. Runs Verilator to generate C++ from the user's RTL
#   2. Generates verifrog_model.h (typedefs for the specific design)
#   3. Compiles the generic shim + Verilator output into libverifrog_sim.dylib/.so

VERILATOR   ?= verilator
BUILD_DIR   ?= build
SHIM_DIR    := $(dir $(lastword $(MAKEFILE_LIST)))
VDIR        := $(BUILD_DIR)/verilated
LIB_NAME    := libverifrog_sim

# Detect platform
UNAME_S := $(shell uname -s)
ifeq ($(UNAME_S),Darwin)
    LIB_EXT     := .dylib
    SHARED_FLAG := -dynamiclib -install_name @rpath/$(LIB_NAME)$(LIB_EXT)
else
    LIB_EXT     := .so
    SHARED_FLAG := -shared
endif

LIB_PATH := $(BUILD_DIR)/$(LIB_NAME)$(LIB_EXT)

# Validate required args
ifndef TOP
    $(error TOP is required. Usage: make sim-lib TOP=counter RTL_SOURCES="counter.v")
endif
ifndef RTL_SOURCES
    $(error RTL_SOURCES is required. Usage: make sim-lib TOP=counter RTL_SOURCES="counter.v")
endif

# Verilator flags
VFLAGS := --cc --top-module $(TOP) --trace --vpi \
          --public-flat-rw \
          -Wno-WIDTHEXPAND -Wno-WIDTHTRUNC -Wno-PINCONNECTEMPTY -Wno-UNUSEDSIGNAL \
          --Mdir $(VDIR)

# Verilator include path
VINC := $(shell $(VERILATOR) --getenv VERILATOR_ROOT)/include

# C++ compiler
CXX      := clang++
CXXFLAGS := -std=c++17 -O2 -fPIC \
            -DVL_USER_STOP \
            -I$(VDIR) -I$(VINC) -I$(VINC)/vltstd -I$(BUILD_DIR)

# Verilator support sources
VSUPPORT := $(VINC)/verilated.cpp \
            $(VINC)/verilated_vcd_c.cpp \
            $(VINC)/verilated_threads.cpp \
            $(VINC)/verilated_vpi.cpp

.PHONY: sim-lib clean verilate model-header

sim-lib: verilate model-header
	$(CXX) $(CXXFLAGS) $(SHARED_FLAG) \
		-o $(LIB_PATH) \
		$(SHIM_DIR)/verifrog_sim.cpp \
		$(wildcard $(VDIR)/*.cpp) \
		$(VSUPPORT)

# Step 1: Run Verilator
verilate:
	@mkdir -p $(BUILD_DIR)
	$(VERILATOR) $(VFLAGS) $(RTL_SOURCES)

# Step 2: Generate verifrog_model.h for this design
model-header:
	@echo '// Auto-generated by verifrog build — do not edit' > $(BUILD_DIR)/verifrog_model.h
	@echo '#pragma once' >> $(BUILD_DIR)/verifrog_model.h
	@echo '#include "V$(TOP).h"' >> $(BUILD_DIR)/verifrog_model.h
	@echo '#include "V$(TOP)___024root.h"' >> $(BUILD_DIR)/verifrog_model.h
	@echo 'typedef V$(TOP) VerifrogModel;' >> $(BUILD_DIR)/verifrog_model.h
	@echo 'typedef V$(TOP)___024root VerifrogModelRoot;' >> $(BUILD_DIR)/verifrog_model.h

clean:
	rm -rf $(BUILD_DIR)
