{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["[", "]"]
  ],
  "autoClosingPairs": [
    { "open": "[", "close": "]" },
    { "open": "\"", "close": "\"" }
  ],
  "surroundingPairs": [
    ["[", "]"],
    ["\"", "\""]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*test\\s+\"",
      "end": "^(?=\\s*test\\s+\")|\\Z"
    }
  },
  "indentationRules": {
    "increaseIndentPattern": "^\\s*test\\s+\"[^\"]*\".*:\\s*$",
    "decreaseIndentPattern": "^\\s*$"
  }
}
